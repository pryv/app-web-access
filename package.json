{
  "author": "kebetsi",
  "name": "app-web-access",
  "version": "2.0.0",
  "description": "This is a web app to generate pryv access tokens.",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "webserver": "backloop.dev ./dist 4443",
    "gh-pages": "node build.js && gh-pages -d dist -m \"publish app-web-access\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pryv/app-web-access"
  },
  "dependencies": {
    "jquery": "^3.7.1",
    "pryv": "^3.5.0"
  },
  "devDependencies": {
    "backloop.dev": "^3.0.2",
    "esbuild": "^0.28.1",
    "gh-pages": "^6.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
